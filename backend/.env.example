# Server
PORT=5000
JWT_SECRET=change_this_to_a_long_random_string

# MySQL (XAMPP / MySQL Community Server defaults shown)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=gst_invoice_db
