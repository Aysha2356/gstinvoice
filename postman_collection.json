{
  "info": {
    "name": "GST Invoice Manager API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo User\",\n  \"email\": \"demo@example.com\",\n  \"password\": \"password123\",\n  \"companyName\": \"Demo Co\",\n  \"companyGSTIN\": \"29ABCDE1234F1Z5\",\n  \"companyAddress\": \"123 Main St\",\n  \"city\": \"Erode\",\n  \"state\": \"Tamil Nadu\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Clients",
      "item": [
        {
          "name": "List clients",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/clients"
          }
        },
        {
          "name": "Create client",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/clients",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corp\",\n  \"gstin\": \"29AACCA1234F1Z1\",\n  \"address\": \"45 Park Ave\",\n  \"city\": \"Chennai\",\n  \"state\": \"Tamil Nadu\",\n  \"email\": \"billing@acme.com\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Invoices",
      "item": [
        {
          "name": "List invoices",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/invoices"
          }
        },
        {
          "name": "Create invoice",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/invoices",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientId\": 1,\n  \"invoiceNumber\": \"INV-001\",\n  \"invoiceDate\": \"2026-06-29\",\n  \"dueDate\": \"2026-07-06\",\n  \"placeOfSupply\": \"Tamil Nadu\",\n  \"notes\": \"It was great doing business with you.\",\n  \"terms\": \"Please make the payment by the due date.\",\n  \"items\": [\n    { \"description\": \"Brochure Design\", \"hsnSac\": \"\", \"qty\": 2, \"rate\": 100, \"sgstPct\": 6, \"cgstPct\": 6, \"cessPct\": 0 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Dashboard stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/invoices/stats/dashboard"
          }
        }
      ]
    },
    {
      "name": "Reminders",
      "item": [
        {
          "name": "Draft AI reminder",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/reminders/1/draft"
          }
        }
      ]
    }
  ]
}
